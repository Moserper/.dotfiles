[core]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path =
	excludesfile = /Users/pathomporn.s/.gitignore_global
	editor = vim
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[commit]
	template = $HOME/.stCommitMsg
[pager]
	diff = true
[init]
	defaultBranch = main
[web]
	browser = ch;;;
[browser "ch"]
	cmd = open -a \"/Applications/Google Chrome.app\"
[alias]
  reflog-prune = reflog expire --expire-unreachable=now --all
	ignore-list = "! cd -- \"${GIT_PREFIX:-.}\" && git ls-files -v ${1:-.} | sed -n -e \"s,^[a-z] \\(.*\\)$,${GIT_PREFIX:-./}\\1,p\" && git status --ignored --porcelain ${1:-.} 2>/dev/null | sed -n -e \"s/^\\(\\!\\! \\)\\(.*\\)$/\\2/p\" #"
	amend = "commit --amend --no-edit"
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --
  stash-unselect = "stash --include-untracked --keep-index"
  stash-select = "!f() { message=\"--\"; if [ -n \"$1\" ]; then message=\"-m $1\"; fi; git stash push \"$message\" $(git status --short | grep '^[MARCD]' | awk '{printf \"%s \", $2}' | sed 's/ $//'); }; f"
	push-up = !git push --set-upstream origin `git symbolic-ref --short HEAD`
	cn = "!git checkout . && git clean -f -d"
	browse-github = "!f() { open \"$(git ls-remote --get-url $(git config --get branch.$(git branch --show-current).remote) | sed 's|git@[^:]*:\\(.*\\)$|https://github.com/\\1|' | sed 's|\\.git$||')\"; }; f"
	pr-github = "!f() { open \"$(git ls-remote --get-url $(git config --get branch.$(git branch --show-current).remote) | sed 's|git@[^:]*:\\(.*\\)$|https://github.com/\\1|' | sed 's|\\.git$||')/compare/$(git config --get branch.$(git branch --show-current).merge | cut -d / -f 3-)?expand=1\"; }; f"
  browse-bitbucket = "!f() { \
    remote_url=$(git ls-remote --get-url \"$(git config --get branch.$(git branch --show-current).remote)\"); \
    repo_path=$(echo \"$remote_url\" | sed -E 's|git@[^:]*:(.*)\\.git|\\1|;s|https://[^/]*/||;s|\\.git$||'); \
    open \"https://bitbucket.org/$repo_path\"; \
  }; f"
  pr-bitbucket = "!f() { \
    remote_url=$(git ls-remote --get-url \"$(git config --get branch.$(git branch --show-current).remote)\"); \
    base_branch=$(git config --get branch.$(git branch --show-current).merge | cut -d / -f 3-); \
    repo_path=$(echo \"$remote_url\" | sed -E 's|git@bitbucket.org:(.*)\\.git|\\1|;s|https://[^/]*/||;s|\\.git$||'); \
    open \"https://bitbucket.org/$repo_path/pull-requests/new\"; \
  }; f"
	unreach-apply = "!git fsck --unreachable 2>/dev/null | awk \"/commit/ {print \\$3}\" | xargs -n1 -I{} git show -s --format=\"%H %ct %ad %s\" -- {} | sort -k2,2nr | awk \"{\\$2=\\\"\\\"; print}\" | fzf --ansi --multi --prompt=\"unreachable> \" --with-nth=3.. --preview \"git show --color=always --stat --patch -- {1}\" --bind \"enter:execute-silent(bash -c \\\"\n            for c in {+1}; do\n              msg=\\\\\\\"from-unreachable-\\$c\\\\\\\"\n              git show --pretty=format: --patch -- \\\\\\\"\\$c\\\\\\\" | git apply -3 || echo \\\\\\\"skip \\$c\\\\\\\"\n              git stash push -u -m \\\\\\\"\\$msg\\\\\\\" >/dev/null\n              git stash apply stash@{0}\n            done\n        \\\")\""
[pull]
	ff = true
[fetch]
	prune = true
[push]
	autoSetupRemote = true
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path =
[includeIf "gitdir:~/"]
    path = ~/.gitconfig-personal
[includeIf "gitdir:~/w/"]
    path = ~/.gitconfig-work
[credential]
	helper = osxkeychain
