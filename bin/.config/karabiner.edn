        {:des "Open Spotify"
         :rules [[:!!m [:open "/Applications/Spotify.app"]]]}

        {:des "Super Duper Model"
         :rules [
                [[:s :d] ["super-mode" 1] nil {:afterup ["super-mode" 0]}]
                :super-mode
                ;; [:##backslash :grave_accent_and_tilde]
                ;; [:##caps_lock :left_control]
                ;; [:!Sh :!Sleft_arrow]
                ;; [:!Oh :!Oleft_arrow]
                [:##u :!Cz]
                [:##semicolon :right_shift]
                [:##spacebar :right_shift]
                [:##right_command :left_control]
                [:##h :left_arrow]
                [:##l :right_arrow]
                [:##j :down_arrow]
                [:##k :up_arrow]
                ;; [:##r [:grave_accent_and_tilde :t]]
                [:##a :left_option]
                [:##f :right_command]
                [:##y :!Cc]
                [:##o :!Cx]
                [:##p :!Cv]
                [:##n :escape]
                [:##left_command :right_shift]
               ]}
